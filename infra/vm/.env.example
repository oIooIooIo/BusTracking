# Copy this file to .env on the VM, then replace every CHANGE_ME value.
POSTGRES_DB=bus_tracking
POSTGRES_USER=bus_tracking
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DEVICE_API_KEY=CHANGE_ME_DEVICE_API_KEY

BACKEND_IMAGE=bus-tracking-backend:0.1.0
ADMIN_WEB_IMAGE=bus-tracking-admin-web:0.1.0

# The address used by browsers to open the admin site. Examples:
# https://10.20.30.40 or https://bus.example.internal
ADMIN_WEB_ORIGIN=https://VM_IP_OR_DNS

# Directory on the VM containing the HTTPS certificate and private key from IT.
# Required files:
#   tls.crt
#   tls.key
TLS_CERT_DIR=/opt/bus-tracking/secrets/tls
