# Copy this file to .env on the VM, then replace every CHANGE_ME value.
POSTGRES_DB=bus_tracking
POSTGRES_USER=bus_tracking
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
DEVICE_API_KEY=CHANGE_ME_DEVICE_API_KEY

# The address used by browsers to open the admin site. Examples:
# http://10.20.30.40 or https://bus.example.internal
ADMIN_WEB_ORIGIN=http://VM_IP_OR_DNS
