<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bus Tracking"
            android:textColor="#172033"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/deviceStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:text="Preparing device..."
            android:textColor="#445064"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Swipe employee card"
            android:textColor="#172033"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scanResult"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:padding="20dp"
            android:text="Waiting for employee card"
            android:textColor="#445064"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/syncNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Sync now" />
    </LinearLayout>
</ScrollView>
